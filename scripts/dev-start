#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SERVICE_DIR="$ROOT_DIR/apps/service"
WEB_DIR="$ROOT_DIR/apps/web"
SERVICE_PYTHON="$SERVICE_DIR/.venv/bin/python"
SERVICE_PORT="${XVG_SERVICE_PORT:-8000}"
WEB_PORT="${XVG_WEB_PORT:-5173}"
WEB_URL="${XVG_WEB_URL:-http://127.0.0.1:${WEB_PORT}}"
API_BASE="${VITE_API_BASE:-http://127.0.0.1:${SERVICE_PORT}}"
LOG_DIR="${XVG_DEV_LOG_DIR:-$ROOT_DIR/var/log/dev}"
SERVICE_LOG="$LOG_DIR/service.log"
WEB_LOG="$LOG_DIR/web.log"
PIDS=()

open_browser() {
  if command -v open >/dev/null 2>&1; then
    open "$WEB_URL" >/dev/null 2>&1 || true
    return
  fi

  if command -v xdg-open >/dev/null 2>&1; then
    xdg-open "$WEB_URL" >/dev/null 2>&1 || true
  fi
}

cleanup() {
  for pid in "${PIDS[@]:-}"; do
    if kill -0 "$pid" >/dev/null 2>&1; then
      kill "$pid" >/dev/null 2>&1 || true
      wait "$pid" >/dev/null 2>&1 || true
    fi
  done
}

require_running() {
  local pid="$1"
  local name="$2"
  local log_path="$3"

  if ! kill -0 "$pid" >/dev/null 2>&1; then
    echo "${name} failed to start." >&2
    if [[ -f "$log_path" ]]; then
      echo "--- ${name} log ---" >&2
      cat "$log_path" >&2
    fi
    echo "Tip: override ports with XVG_SERVICE_PORT / XVG_WEB_PORT if 8000 or 5173 is busy." >&2
    exit 1
  fi
}

trap cleanup EXIT INT TERM

"$ROOT_DIR/scripts/bootstrap"
mkdir -p "$LOG_DIR"
: > "$SERVICE_LOG"
: > "$WEB_LOG"

echo "Starting local API on http://127.0.0.1:${SERVICE_PORT}"
(
  cd "$SERVICE_DIR"
  "$SERVICE_PYTHON" -m uvicorn xcpc_vp_gather.main:app --reload --host 127.0.0.1 --port "$SERVICE_PORT"
) >"$SERVICE_LOG" 2>&1 &
PIDS+=("$!")

echo "Starting web UI on ${WEB_URL}"
(
  cd "$WEB_DIR"
  VITE_API_BASE="$API_BASE" npm run dev -- --host 127.0.0.1 --port "$WEB_PORT"
) >"$WEB_LOG" 2>&1 &
PIDS+=("$!")

sleep 2
require_running "${PIDS[0]}" "Local API" "$SERVICE_LOG"
require_running "${PIDS[1]}" "Web UI" "$WEB_LOG"
open_browser

echo "xcpc-vp-gather is running."
echo "Web: ${WEB_URL}"
echo "API: ${API_BASE}"
echo "Logs: $SERVICE_LOG , $WEB_LOG"
echo "Press Ctrl+C to stop."

wait "${PIDS[@]}"
