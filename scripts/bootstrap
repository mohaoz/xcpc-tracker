#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SERVICE_DIR="$ROOT_DIR/apps/service"
WEB_DIR="$ROOT_DIR/apps/web"
SERVICE_VENV="$SERVICE_DIR/.venv"
SERVICE_PYTHON="$SERVICE_VENV/bin/python"
FORCE_BOOTSTRAP="${XVG_BOOTSTRAP_FORCE:-0}"

require_command() {
  local command_name="$1"
  if ! command -v "$command_name" >/dev/null 2>&1; then
    echo "Missing required command: $command_name" >&2
    exit 1
  fi
}

bootstrap_service() {
  require_command python3

  if [[ ! -x "$SERVICE_PYTHON" ]]; then
    echo "Creating service virtual environment..."
    python3 -m venv "$SERVICE_VENV"
  fi

  if [[ "$FORCE_BOOTSTRAP" != "1" ]] && "$SERVICE_VENV/bin/xvg" --help >/dev/null 2>&1; then
    echo "Service dependencies already available."
    return
  fi

  echo "Installing service dependencies..."
  (
    cd "$SERVICE_DIR"
    "$SERVICE_PYTHON" -m pip install -e '.[dev]'
  )
}

bootstrap_web() {
  require_command npm

  if [[ "$FORCE_BOOTSTRAP" != "1" ]] && [[ -d "$WEB_DIR/node_modules" ]]; then
    echo "Web dependencies already available."
    return
  fi

  echo "Installing web dependencies..."
  npm install
}

bootstrap_service
(
  cd "$WEB_DIR"
  bootstrap_web
)
