{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xcpc-tracker.local/schemas/contest.schema.json",
  "title": "CuratedContest",
  "type": "object",
  "required": [
    "id",
    "title",
    "aliases",
    "tags",
    "sources",
    "problems",
    "curation_status"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "start_at": {
      "type": "string"
    },
    "curation_status": {
      "type": "string",
      "enum": ["contest_stub", "problem_listed", "reviewed"]
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["provider", "kind", "url"],
        "additionalProperties": false,
        "properties": {
          "provider": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "provider_contest_id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          }
        }
      }
    },
    "problems": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "ordinal", "title", "aliases", "sources"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "ordinal": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["provider", "kind", "url"],
              "additionalProperties": false,
              "properties": {
                "provider": {
                  "type": "string"
                },
                "kind": {
                  "type": "string"
                },
                "url": {
                  "type": "string",
                  "format": "uri"
                },
                "provider_problem_id": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
